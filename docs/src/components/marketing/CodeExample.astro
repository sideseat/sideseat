<section class="section section-contrast">
  <div class="container">
    <div class="section-header center">
      <p class="eyebrow">Instrument once</p>
      <h2 class="section-title">Add two lines. Capture every agent run.</h2>
      <p class="section-lead">Drop in the OpenTelemetry exporter and SideSeat renders traces instantly.</p>
    </div>

    <div class="steps">
      <div class="step">1. Install the SDK</div>
      <div class="step">2. Initialize SideSeat</div>
      <div class="step">3. Run your agent locally</div>
    </div>

    <div class="section-header center" style="margin-bottom: 20px;">
      <div class="code-tabs" role="tablist" aria-label="SDK selector">
        <button class="code-tab is-active" data-tab="python" role="tab" aria-selected="true">Strands Agents</button>
        <button class="code-tab" data-tab="bedrock" role="tab" aria-selected="false">Amazon Bedrock</button>
        <button class="code-tab" data-tab="openai" role="tab" aria-selected="false">OpenAI</button>
        <button class="code-tab" data-tab="anthropic" role="tab" aria-selected="false">Anthropic</button>
        <button class="code-tab" data-tab="vertex" role="tab" aria-selected="false">Google Vertex AI</button>
      </div>
    </div>

    <div class="code-panel" data-panel="python">
      <div class="terminal">
        <div class="terminal-header">
          <div class="terminal-dot red"></div>
          <div class="terminal-dot yellow"></div>
          <div class="terminal-dot green"></div>
          <span class="terminal-title">your_agent.py</span>
        </div>
        <div class="terminal-body">
          <pre><code>from strands import Agent
<span class="text-accent">from sideseat import SideSeat, Frameworks</span>

<span class="text-accent">SideSeat(framework=Frameworks.Strands)</span>   <span class="text-muted"># add this</span>

agent = Agent()  <span class="text-muted"># uses Amazon Bedrock by default</span>
agent("Analyze this dataset...")</code></pre>
        </div>
      </div>
    </div>

    <div class="code-panel hidden" data-panel="bedrock">
      <div class="terminal">
        <div class="terminal-header">
          <div class="terminal-dot red"></div>
          <div class="terminal-dot yellow"></div>
          <div class="terminal-dot green"></div>
          <span class="terminal-title">your_app.py</span>
        </div>
        <div class="terminal-body">
          <pre><code>import boto3
<span class="text-accent">from sideseat import SideSeat, Frameworks</span>

<span class="text-accent">SideSeat(framework=Frameworks.Bedrock)</span>   <span class="text-muted"># add this</span>

bedrock = boto3.client("bedrock-runtime", region_name="us-east-1")
response = bedrock.converse(
    modelId="us.anthropic.claude-sonnet-4-5-20250929-v1:0",
    messages=[&#123;"role": "user", "content": [&#123;"text": "Analyze this dataset..."&#125;]&#125;],
)

print(response["output"]["message"]["content"][0]["text"])</code></pre>
        </div>
      </div>
    </div>

    <div class="code-panel hidden" data-panel="openai">
      <div class="terminal">
        <div class="terminal-header">
          <div class="terminal-dot red"></div>
          <div class="terminal-dot yellow"></div>
          <div class="terminal-dot green"></div>
          <span class="terminal-title">your_app.py</span>
        </div>
        <div class="terminal-body">
          <pre><code>from openai import OpenAI
<span class="text-accent">from sideseat import SideSeat, Frameworks</span>

<span class="text-accent">SideSeat(framework=Frameworks.OpenAI)</span>   <span class="text-muted"># add this</span>

client = OpenAI()
response = client.chat.completions.create(
    model="gpt-5-mini",
    messages=[&#123;"role": "user", "content": "Analyze this dataset..."&#125;],
)

print(response.choices[0].message.content)</code></pre>
        </div>
      </div>
    </div>

    <div class="code-panel hidden" data-panel="anthropic">
      <div class="terminal">
        <div class="terminal-header">
          <div class="terminal-dot red"></div>
          <div class="terminal-dot yellow"></div>
          <div class="terminal-dot green"></div>
          <span class="terminal-title">your_app.py</span>
        </div>
        <div class="terminal-body">
          <pre><code>import anthropic
<span class="text-accent">from sideseat import SideSeat, Frameworks</span>

<span class="text-accent">SideSeat(framework=Frameworks.Anthropic)</span>   <span class="text-muted"># add this</span>

client = anthropic.Anthropic()
message = client.messages.create(
    model="claude-sonnet-4-5-20250929",
    max_tokens=1024,
    messages=[&#123;"role": "user", "content": "Analyze this dataset..."&#125;],
)

print(message.content[0].text)</code></pre>
        </div>
      </div>
    </div>

    <div class="code-panel hidden" data-panel="vertex">
      <div class="terminal">
        <div class="terminal-header">
          <div class="terminal-dot red"></div>
          <div class="terminal-dot yellow"></div>
          <div class="terminal-dot green"></div>
          <span class="terminal-title">your_app.py</span>
        </div>
        <div class="terminal-body">
          <pre><code>import vertexai
from vertexai.generative_models import GenerativeModel
<span class="text-accent">from sideseat import SideSeat, Frameworks</span>

<span class="text-accent">SideSeat(framework=Frameworks.VertexAI)</span>   <span class="text-muted"># add this</span>

vertexai.init(project="your-project", location="us-central1")
model = GenerativeModel("gemini-2.5-flash")
response = model.generate_content("Analyze this dataset...")

print(response.text)</code></pre>
        </div>
      </div>
    </div>

    <p class="code-note">Open <span class="text-accent">localhost:5388</span> to inspect the run in SideSeat.</p>
  </div>
</section>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const tabs = document.querySelectorAll('.code-tab');
    const panels = document.querySelectorAll('.code-panel');

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const target = tab.getAttribute('data-tab');

        tabs.forEach((t) => {
          const isActive = t === tab;
          t.classList.toggle('is-active', isActive);
          t.setAttribute('aria-selected', isActive ? 'true' : 'false');
        });

        panels.forEach((panel) => {
          const matches = panel.getAttribute('data-panel') === target;
          panel.classList.toggle('hidden', !matches);
        });
      });
    });
  });
</script>
