# Server Configuration
SIDESEAT_HOST=127.0.0.1
SIDESEAT_PORT=5001

# Logging (SIDESEAT_LOG takes priority over RUST_LOG)
SIDESEAT_LOG=info,sideseat=debug

# Storage Path Overrides (optional)
# SIDESEAT_CONFIG_DIR=/path/to/config
# SIDESEAT_DATA_DIR=/path/to/data
# SIDESEAT_CACHE_DIR=/path/to/cache

# Secret Backend Override (optional)
# Valid values: keychain (macOS), credential-manager (Windows), secret-service (Linux), keyutils (Linux)
# SIDESEAT_SECRET_BACKEND=keychain

# Security Note: Never commit .env file with real credentials
